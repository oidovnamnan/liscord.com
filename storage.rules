rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuth() {
      return request.auth != null;
    }

    // Public paths (community images uploaded by store customers, and public read for business files)
    match /businesses/{bizId}/community_feeds/{imageId} {
      allow read: if true;
      allow write: if true; 
    }

    // Business files — only members can write, public can read (for storefront catalog)
    match /businesses/{bizId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAuth();
    }

    // System Branding files — anyone can read, Authenticated can upload
    match /system/{allPaths=**} {
      allow read: if true;
      allow write: if isAuth();
    }

    // User files — only the user themselves
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
  }
}
