rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuth() {
      return request.auth != null;
    }

    // Business files — only members can read/write
    match /businesses/{bizId}/{allPaths=**} {
      allow read: if isAuth() && exists(/databases/$(database)/documents/businesses/$(bizId)/employees/$(request.auth.uid));
      allow write: if isAuth() && exists(/databases/$(database)/documents/businesses/$(bizId)/employees/$(request.auth.uid));
    }

    // User files — only the user themselves
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
  }
}
