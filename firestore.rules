rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // === HELPER FUNCTIONS ===
    function isAuth() {
      return request.auth != null;
    }

    // === USERS ===
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      
      // Device tracking for remote logout
      match /devices/{deviceId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // === SYSTEM SETTINGS (Super Admin only via Admin SDK) ===
    match /systemSettings/{docId} {
      allow read: if isAuth();
      allow write: if false; // Admin SDK only
    }

    // system_settings (snake_case — used by services)
    match /system_settings/{docId} {
      allow read: if isAuth();
      allow write: if isAuth(); // Super Admin writes module defaults
    }

    // === BUSINESS CATEGORIES (public read) ===
    match /businessCategories/{catId} {
      allow read: if isAuth();
      allow write: if false; // Admin SDK only
    }

    // === BUSINESS REQUESTS ===
    match /businessRequests/{reqId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false; // Admin SDK only
    }

    // === PLATFORM PAYMENTS ===
    match /platformPayments/{payId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false; // Admin SDK only
    }

    // === QR LOGINS ===
    match /qr_logins/{sessionId} {
      allow read, update: if true;
      allow create, delete: if isAuth();
    }
    
    // === SMS INBOX (Bridge App) ===
    match /sms_inbox/{smsId} {
      allow create, update: if true;
      allow read, delete: if isAuth();
    }
    
    // === BUSINESSES ===
    // Read: any authenticated user (access control handled in app layer)
    // Write: any authenticated user (fine-grained permissions handled in app layer)
    // Note: isMember/hasPerm checks removed because employee docs use auto-generated IDs,
    // not auth.uid as document ID, making exists() checks impossible.
    match /businesses/{bizId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if false; // Never delete via client
      
      // All subcollections: authenticated read/write
      match /{subcollection}/{docId} {
        allow read: if isAuth();
        allow create, update: if isAuth();
        allow delete: if false;
      }

      // Nested subcollections (e.g. warehouses/zones)
      match /{subcollection}/{docId}/{nestedSub}/{nestedDocId} {
        allow read: if isAuth();
        allow create, update: if isAuth();
        allow delete: if false;
      }
    }
  }
}
