rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // === HELPER FUNCTIONS ===
    function isAuth() {
      return request.auth != null;
    }
    
    function isMemberOf(bizId) {
      // Check if user has this business in their businessIds array
      return isAuth() && bizId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessIds;
    }

    // === USERS ===
    match /users/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
      
      // Device tracking for remote logout
      match /devices/{deviceId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // === SYSTEM SETTINGS (Super Admin only via Admin SDK) ===
    match /systemSettings/{docId} {
      allow read: if isAuth();
      allow write: if false; // Admin SDK only
    }

    // system_settings (snake_case — used by services)
    match /system_settings/{docId} {
      allow read: if isAuth();
      allow write: if false; // Admin SDK only — SuperAdmin writes via Cloud Function proxy
    }

    // === BUSINESS CATEGORIES (public read) ===
    match /businessCategories/{catId} {
      allow read: if isAuth();
      allow write: if false; // Admin SDK only
    }

    // system_categories (snake_case — used by Module Settings page)
    match /system_categories/{catId} {
      allow read: if isAuth();
      allow write: if false; // Admin SDK only — SuperAdmin writes via Cloud Function proxy
    }

    // === BUSINESS REQUESTS ===
    match /businessRequests/{reqId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false; // Admin SDK only
    }

    // === PLATFORM PAYMENTS ===
    match /platformPayments/{payId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false; // Admin SDK only
    }

    // === QR LOGINS ===
    match /qr_logins/{sessionId} {
      allow read, update: if true;
      allow create, delete: if isAuth();
    }
    
    // === SMS INBOX (Bridge App) ===
    match /sms_inbox/{smsId} {
      allow create: if true;  // Bridge app creates without auth (Phase 4: add auth)
      allow update: if isAuth();  // Only authenticated users can update (match/status)
      allow read, delete: if isAuth();
    }
    
    // === BUSINESSES ===
    match /businesses/{bizId} {
      // Public read: allow listing businesses by slug (for storefront)
      // Firestore 'list' (query) requires access at collection level
      allow list: if true;
      // Get: members OR storefront slug lookup (public)
      allow get: if isMemberOf(bizId) || resource.data.slug != null;
      // Create: any authenticated user (creating new business)
      allow create: if isAuth();
      // Update: only members
      allow update: if isMemberOf(bizId);
      // Delete: never via client
      allow delete: if false;
      
      // Public storefront subcollections (products, categories, module_settings)
      match /products/{docId} {
        allow read: if true;  // Public: storefront catalog
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }

      match /categories/{docId} {
        allow read: if true;  // Public: storefront category filter
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }

      match /module_settings/{docId} {
        allow read: if true;  // Public: storefront theme settings
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }

      // Orders: public CRUD (storefront checkout + QPay invoice ID save)
      // Payment verification goes through /api/qpay-callback (Admin SDK)
      match /orders/{docId} {
        allow read, create, update: if true;
        allow delete: if false;
      }

      // Memberships: public read + create (storefront VIP purchase flow)
      // QPay callback (Admin SDK) is unavailable on Vercel — client creates membership
      match /memberships/{docId} {
        allow read, create: if true;
        allow update: if isMemberOf(bizId);
        allow delete: if false;
      }

      // Payment settings: public read (checkout needs bank details)
      match /payment_settings/{docId} {
        allow read: if true;
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }

      // Facebook Messenger settings: business members only
      match /fbSettings/{docId} {
        allow read, write: if isMemberOf(bizId);
      }

      // Facebook Messenger conversations + messages
      match /fbConversations/{convId} {
        allow read, write: if isMemberOf(bizId);
        match /messages/{msgId} {
          allow read, write: if isMemberOf(bizId);
        }
      }

      // Stock inquiries: public create+read (storefront popup), update members only
      match /stockInquiries/{docId} {
        allow read, create: if true;  // Public: storefront creates inquiry + listens for response
        allow update: if isMemberOf(bizId);  // Only agents can respond
        allow delete: if false;
      }

      // All other subcollections: member read/write only
      match /{subcollection}/{docId} {
        allow read: if isMemberOf(bizId);
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }

      // Nested subcollections (e.g. warehouses/zones)
      match /{subcollection}/{docId}/{nestedSub}/{nestedDocId} {
        allow read: if isMemberOf(bizId);
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }
    }
  }
}
