rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // === HELPER FUNCTIONS ===
    function isAuth() {
      return request.auth != null;
    }
    
    function isMemberOf(bizId) {
      // Check if user has this business in their businessIds array
      return isAuth() && bizId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessIds;
    }

    function isSuperAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isSuperAdmin == true;
    }

    // === USERS ===
    match /users/{userId} {
      allow read: if isAuth() && request.auth.uid == userId;
      // Prevent self-promotion: block client-side changes to isSuperAdmin
      allow create: if isAuth() && request.auth.uid == userId
        && (!('isSuperAdmin' in request.resource.data) || request.resource.data.isSuperAdmin == false);
      allow update: if isAuth() && request.auth.uid == userId
        && (!('isSuperAdmin' in resource.data) || 
            request.resource.data.isSuperAdmin == resource.data.isSuperAdmin);
      allow delete: if false;
      
      // Device tracking for remote logout
      match /devices/{deviceId} {
        allow read, write: if isAuth() && request.auth.uid == userId;
      }
    }

    // === SYSTEM SETTINGS (Super Admin) ===
    match /systemSettings/{docId} {
      allow read: if true;  // Public: storefront needs global settings (currency, language)
      allow write: if isSuperAdmin();
    }

    // system_settings (snake_case — used by services)
    match /system_settings/{docId} {
      allow read: if true;  // Public: storefront needs global settings
      allow write: if isSuperAdmin();
    }

    // === BUSINESS CATEGORIES ===
    match /businessCategories/{catId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // system_categories (snake_case — used by Module Settings page)
    match /system_categories/{catId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // === BUSINESS REQUESTS ===
    match /businessRequests/{reqId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false; // Admin SDK only
    }

    // === PLATFORM PAYMENTS ===
    match /platformPayments/{payId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false; // Admin SDK only
    }

    // === EMPLOYEE PHONE MAP ===
    // Authenticated users can read (autoLinkEmployee on login) and write (owner manages employees)
    match /employee_phone_map/{phoneId} {
      allow read: if isAuth();
      allow create, update, delete: if isAuth();
    }

    // === QR LOGINS ===
    match /qr_logins/{sessionId} {
      // Read: anyone can poll status (desktop needs to check before auth)
      // Update: anyone can update (mobile scans QR before desktop is authed)
      // But customToken is written by Cloud Function (Admin SDK), not client
      allow read: if true;
      allow update: if true;
      allow create: if isAuth();
      allow delete: if false;
    }
    
    // === SMS INBOX (Bridge App) ===
    // Bridge app uses Firestore REST API with API key — no Firebase Auth
    // Validated by pairingKey field (shared secret between web + bridge)
    match /sms_inbox/{smsId} {
      allow create: if true;  // Bridge app creates without auth — validated by pairingKey in Cloud Function
      allow update: if isAuth();  // Only authenticated users can update (match/status)
      allow read: if isAuth();
      allow delete: if isAuth();
    }

    // === SMS OUTBOX (Web → Bridge App sends SMS) ===
    // Bridge app polls for pending messages using pairingKey query
    match /sms_outbox/{docId} {
      allow create: if isAuth();        // Web app creates outbox messages
      allow read, update: if true;      // Bridge app reads pending + updates status (no auth — uses pairingKey)
      allow delete: if isAuth();        // Cleanup by authenticated users
    }
    
    // === BUSINESSES ===
    match /businesses/{bizId} {
      // List + Get: public read for storefront (slug lookup + catalog)
      // Business names/slugs/logos are not sensitive — needed for public storefront
      allow read: if true;
      // Create: any authenticated user (creating new business)
      allow create: if isAuth();
      // Update: only members
      allow update: if isMemberOf(bizId);
      // Delete: never via client
      allow delete: if false;
      
      // Public storefront subcollections (products, categories, module_settings)
      match /products/{docId} {
        allow read: if true;  // Public: storefront catalog
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }

      match /categories/{docId} {
        allow read: if true;  // Public: storefront category filter
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }

      match /module_settings/{docId} {
        allow read: if true;  // Public: storefront theme settings
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }

      // Orders: storefront can create + read, members have full update access
      // QPay payment confirmation: unauthenticated users can ONLY update payment-related fields
      match /orders/{docId} {
        allow read: if true;            // Storefront needs to poll order status after QPay
        allow create: if true;          // Storefront checkout creates orders
        allow delete: if false;

        // Business members: full update
        // Storefront (unauthenticated): only payment fields
        allow update: if isMemberOf(bizId)
          || (
            // Only allow changing these specific payment fields
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'paymentStatus', 'paymentVerifiedAt', 'paymentVerifiedBy', 'financials'])
            // paymentStatus can only be set to 'paid'
            && request.resource.data.paymentStatus == 'paid'
          );
      }

      // Memberships: public read + create (storefront VIP purchase flow)
      // QPay callback (Admin SDK) is unavailable on Vercel — client creates membership
      match /memberships/{docId} {
        allow read, create: if true;
        allow update: if isMemberOf(bizId);
        allow delete: if false;
      }

      // Payment settings: member-only (QPay credentials are sensitive)
      // Storefront uses /api/qpay-invoice serverless function instead
      match /payment_settings/{docId} {
        allow read: if isMemberOf(bizId);
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }

      // Facebook Messenger settings: member-only read/write
      // fb-webhook uses Firestore REST API with server-side API key (not client auth)
      // fb-send uses Firestore REST API with server-side API key
      match /fbSettings/{docId} {
        allow read: if true;  // Server-side REST API (fb-send, fb-webhook) needs unauthenticated read
        allow write: if isMemberOf(bizId);
      }

      // Facebook Messenger conversations + messages
      // Public write: webhook creates conversations without auth (like orders)
      // Read: members only
      match /fbConversations/{convId} {
        allow read: if isMemberOf(bizId);
        allow create, update: if true;  // Webhook writes without admin SDK
        allow delete: if false;
        match /messages/{msgId} {
          allow read: if isMemberOf(bizId);
          allow create: if true;  // Webhook writes without admin SDK
          allow update: if isMemberOf(bizId);
          allow delete: if false;
        }
      }

      // Stock inquiries: public create+read (storefront popup), update members only
      match /stockInquiries/{docId} {
        allow read, create: if true;  // Public: storefront creates inquiry + listens for response
        allow update: if isMemberOf(bizId);  // Only agents can respond
        allow delete: if false;
      }

      // Visitors: public create+update+delete (anonymous storefront heartbeat tracking)
      // Each visitor writes lastActiveAt every 30s and deletes on tab close
      match /visitors/{docId} {
        allow read: if isMemberOf(bizId);    // Only dashboard reads visitors
        allow create, update: if true;       // Anonymous storefront writes heartbeat
        allow delete: if true;               // Cleanup on tab close (deleteDoc on unmount)
      }

      // Daily stats: public increment (storefront visitor counter), member read
      match /daily_stats/{docId} {
        allow read: if isMemberOf(bizId);
        allow create, update: if true;       // Storefront increments visitorCount
        allow delete: if false;
      }

      // SMS Templates: member-only CRUD (including delete for custom templates)
      match /smsTemplates/{docId} {
        allow read: if isMemberOf(bizId);
        allow create, update, delete: if isMemberOf(bizId);
      }

      // QPay income: member read, public create (from server callbacks)
      match /qpay_income/{docId} {
        allow read: if isMemberOf(bizId);
        allow create: if true;  // QPay callback writes without auth
        allow update: if isMemberOf(bizId);
        allow delete: if false;
      }

      // Promo Codes: member CRUD including delete
      match /promoCodes/{docId} {
        allow read: if isMemberOf(bizId);
        allow create, update, delete: if isMemberOf(bizId);
      }

      // Promo Credits: public read (storefront profile), member write
      match /promoCredits/{docId} {
        allow read: if true;
        allow create, update: if true;  // Storefront creates credits on code generation
        allow delete: if isMemberOf(bizId);
      }

      // All other subcollections: member read/write only
      match /{subcollection}/{docId} {
        allow read: if isMemberOf(bizId);
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }

      // Nested subcollections (e.g. warehouses/zones)
      match /{subcollection}/{docId}/{nestedSub}/{nestedDocId} {
        allow read: if isMemberOf(bizId);
        allow create, update: if isMemberOf(bizId);
        allow delete: if false;
      }
    }
  }
}
